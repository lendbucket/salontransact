generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                     String    @id @default(cuid())
  name                   String?
  email                  String    @unique
  emailVerified          DateTime?
  emailVerificationToken String?   @unique
  image                  String?
  password               String?
  role                   String    @default("merchant")
  approvalStatus         String    @default("pending")
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  accounts               Account[]
  sessions               Session[]
  merchant               Merchant?
  merchantApplication    MerchantApplication?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model Merchant {
  id                    String        @id @default(cuid())
  userId                String        @unique
  businessName          String
  businessType          String?
  email                 String
  phone                 String?
  address               String?
  city                  String?
  state                 String?
  zip                   String?
  stripeAccountId       String?       @unique
  stripeAccountStatus   String        @default("pending")
  stripeOnboardingUrl   String?
  payoutsEnabled        Boolean       @default(false)
  chargesEnabled        Boolean       @default(false)
  monthlyVolume         Float         @default(0)
  totalVolume           Float         @default(0)
  totalTransactions     Int           @default(0)
  plan                  String        @default("starter")
  status                String        @default("active")
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  ein                   String?
  dbaName               String?
  ownerFirstName        String?
  ownerLastName         String?
  ownerDob              String?
  ownerSsnLast4         String?
  ownerTitle            String?
  ownershipPercentage   Int?
  ownerAddress          String?
  bankAccountHolder     String?
  bankRoutingNumber     String?
  bankAccountNumber     String?
  bankAccountType       String?
  fundingSpeed          String?
  avgTransaction        String?
  paymentMethods        String[]
  applicationSubmittedAt DateTime?
  user                  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions          Transaction[]
  payouts               Payout[]
  apiKeys               ApiKey[]
  webhooks              Webhook[]
  savedPaymentMethods   SavedPaymentMethod[]
  devices               Device[]
}

model Transaction {
  id               String    @id @default(cuid())
  merchantId       String
  stripePaymentId  String?   @unique
  amount           Float
  currency         String    @default("usd")
  status           String
  description      String?
  customerEmail    String?
  customerName     String?
  fee              Float     @default(0)
  net              Float     @default(0)
  refunded         Boolean   @default(false)
  refundAmount     Float     @default(0)
  metadata         Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  merchant         Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
}

model Payout {
  id             String    @id @default(cuid())
  merchantId     String
  stripePayoutId String?   @unique
  amount         Float
  currency       String    @default("usd")
  status         String
  arrivalDate    DateTime?
  description    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  merchant       Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
}

model ApiKey {
  id         String    @id @default(cuid())
  merchantId String
  name       String
  key        String    @unique
  lastUsed   DateTime?
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now())
  merchant   Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
}

model Webhook {
  id         String    @id @default(cuid())
  merchantId String
  url        String
  events     String[]
  active     Boolean   @default(true)
  secret     String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  merchant   Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
}

model Invite {
  id        String    @id @default(cuid())
  email     String    @unique
  token     String    @unique @default(cuid())
  used      Boolean   @default(false)
  usedAt    DateTime?
  expiresAt DateTime
  createdAt DateTime  @default(now())
  sentBy    String
}

model PasswordReset {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique @default(cuid())
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model PayrocToken {
  id        String   @id @default(cuid())
  token     String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Affiliate {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  referralCode   String   @unique
  commissionRate Float    @default(10)
  status         String   @default("active")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  referredCount  Int      @default(0)
}

model RefundOperation {
  id                  String   @id @default(cuid())
  operation           String
  payrocPaymentId     String
  payrocRefundId      String?
  idempotencyKey      String   @unique
  amountCents         Int
  description         String?
  operatorUserId      String
  operatorEmail       String
  merchantId          String?
  status              String
  payrocRequestBody   Json?
  payrocResponseBody  Json?
  payrocStatusCode    Int?
  errorMessage        String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([payrocPaymentId])
  @@index([merchantId])
  @@index([operatorUserId])
  @@index([createdAt])
}

model SavedPaymentMethod {
  id                  String    @id @default(cuid())
  merchantId          String
  customerEmail       String
  payrocSecureTokenId String    @unique
  payrocToken         String?
  cardScheme          String?
  last4               String?
  expiryMonth         String?
  expiryYear          String?
  cardholderName      String?
  label               String?
  status              String    @default("active")
  mitAgreement        String    @default("unscheduled")
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  lastUsedAt          DateTime?

  merchant            Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId, customerEmail])
  @@index([payrocSecureTokenId])
  @@index([status])
  @@index([createdAt])
}

model Device {
  id            String    @id @default(cuid())
  merchantId    String
  serialNumber  String    @unique
  model         String?
  label         String?
  status        String    @default("active")
  pairedAt      DateTime  @default(now())
  lastSeenAt    DateTime?
  lastChargeAt  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  merchant      Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId])
  @@index([status])
  @@index([createdAt])
}

model PayrocPaymentRecord {
  id              String   @id @default(cuid())
  payrocPaymentId String   @unique
  merchantId      String
  amountCents     Int
  currency        String   @default("USD")
  status          String
  source          String
  recordedAt      DateTime @default(now())
  createdAt       DateTime @default(now())

  @@index([merchantId])
  @@index([payrocPaymentId])
  @@index([recordedAt])
}

model WebhookEvent {
  id           String    @id @default(cuid())
  source       String
  eventId      String    @unique
  eventType    String
  payload      Json
  status       String    @default("received")
  processedAt  DateTime?
  errorMessage String?
  ipAddress    String?
  receivedAt   DateTime  @default(now())

  @@index([source])
  @@index([eventType])
  @@index([status])
  @@index([receivedAt])
}

model MerchantApplication {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  legalBusinessName String
  dba               String?
  businessType      String
  ein               String
  businessPhone     String
  website           String?

  addressStreet     String
  addressCity       String
  addressState      String
  addressZip        String
  addressCountry    String   @default("US")

  ownerFullName     String
  ownerEmail        String
  ownerPhone        String
  ownerTitle        String   @default("Owner")

  bankName          String
  accountHolderName String
  routingNumber     String
  accountNumber     String
  accountType       String

  monthlyVolume     String
  averageTicket     String
  mccCode           String
  agreementAccepted Boolean  @default(false)

  status            String   @default("submitted")
  submittedAt       DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorId     String
  actorEmail  String
  actorRole   String
  action      String
  targetType  String
  targetId    String
  merchantId  String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([actorId])
  @@index([merchantId])
  @@index([targetType, targetId])
  @@index([action])
  @@index([createdAt])
}
