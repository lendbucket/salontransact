generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("merchant")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  merchant      Merchant?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model Merchant {
  id                    String        @id @default(cuid())
  userId                String        @unique
  businessName          String
  businessType          String?
  email                 String
  phone                 String?
  address               String?
  city                  String?
  state                 String?
  zip                   String?
  stripeAccountId       String?       @unique
  stripeAccountStatus   String        @default("pending")
  stripeOnboardingUrl   String?
  payoutsEnabled        Boolean       @default(false)
  chargesEnabled        Boolean       @default(false)
  monthlyVolume         Float         @default(0)
  totalVolume           Float         @default(0)
  totalTransactions     Int           @default(0)
  plan                  String        @default("starter")
  status                String        @default("active")
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  user                  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions          Transaction[]
  payouts               Payout[]
  apiKeys               ApiKey[]
  webhooks              Webhook[]
}

model Transaction {
  id               String    @id @default(cuid())
  merchantId       String
  stripePaymentId  String?   @unique
  amount           Float
  currency         String    @default("usd")
  status           String
  description      String?
  customerEmail    String?
  customerName     String?
  fee              Float     @default(0)
  net              Float     @default(0)
  refunded         Boolean   @default(false)
  refundAmount     Float     @default(0)
  metadata         Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  merchant         Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
}

model Payout {
  id             String    @id @default(cuid())
  merchantId     String
  stripePayoutId String?   @unique
  amount         Float
  currency       String    @default("usd")
  status         String
  arrivalDate    DateTime?
  description    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  merchant       Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
}

model ApiKey {
  id         String    @id @default(cuid())
  merchantId String
  name       String
  key        String    @unique
  lastUsed   DateTime?
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now())
  merchant   Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
}

model Webhook {
  id         String    @id @default(cuid())
  merchantId String
  url        String
  events     String[]
  active     Boolean   @default(true)
  secret     String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  merchant   Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
}

model Invite {
  id        String    @id @default(cuid())
  email     String    @unique
  token     String    @unique @default(cuid())
  used      Boolean   @default(false)
  usedAt    DateTime?
  expiresAt DateTime
  createdAt DateTime  @default(now())
  sentBy    String
}
