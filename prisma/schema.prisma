generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                     String    @id @default(cuid())
  name                   String?
  email                  String    @unique
  emailVerified          DateTime?
  emailVerificationToken String?   @unique
  image                  String?
  password               String?
  role                   String    @default("merchant")
  approvalStatus               String    @default("pending")
  notificationDigestFrequency  String    @default("off")
  notificationLastDigestSentAt DateTime?
  createdAt                    DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  accounts               Account[]
  sessions               Session[]
  merchant               Merchant?
  merchantApplication    MerchantApplication?
  notifications          Notification[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model Merchant {
  id                    String        @id @default(cuid())
  userId                String        @unique
  businessName          String
  businessType          String?
  email                 String
  phone                 String?
  address               String?
  city                  String?
  state                 String?
  zip                   String?
  stripeAccountId       String?       @unique
  stripeAccountStatus   String        @default("pending")
  stripeOnboardingUrl   String?
  payoutsEnabled        Boolean       @default(false)
  chargesEnabled        Boolean       @default(false)
  monthlyVolume         Float         @default(0)
  totalVolume           Float         @default(0)
  totalTransactions     Int           @default(0)
  plan                  String        @default("starter")
  status                String        @default("active")
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  ein                   String?
  dbaName               String?
  ownerFirstName        String?
  ownerLastName         String?
  ownerDob              String?
  ownerSsnLast4         String?
  ownerTitle            String?
  ownershipPercentage   Int?
  ownerAddress          String?
  bankAccountHolder     String?
  bankRoutingNumber     String?
  bankAccountNumber     String?
  bankAccountType       String?
  fundingSpeed          String?
  avgTransaction        String?
  paymentMethods        String[]
  applicationSubmittedAt DateTime?
  user                  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions          Transaction[]
  payouts               Payout[]
  apiKeys               ApiKey[]
  webhooks              Webhook[]
  savedPaymentMethods   SavedPaymentMethod[]
  devices               Device[]
  batches               Batch[]
  contracts             Contract[]
  customers             Customer[]
}

model Transaction {
  id               String    @id @default(cuid())
  merchantId       String
  stripePaymentId  String?   @unique
  amount           Float
  currency         String    @default("usd")
  status           String
  description      String?
  customerEmail    String?
  customerName     String?
  customerId       String?
  fee              Float     @default(0)
  net              Float     @default(0)
  refunded         Boolean   @default(false)
  refundAmount     Float     @default(0)
  metadata         Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  merchant         Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  customer         Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([customerId])
}

model Payout {
  id             String    @id @default(cuid())
  merchantId     String
  stripePayoutId String?   @unique
  amount         Float
  currency       String    @default("usd")
  status         String
  arrivalDate    DateTime?
  description    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  batchId        String?
  batch          Batch?    @relation(fields: [batchId], references: [id])
  merchant       Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([batchId])
}

model ApiKey {
  id         String    @id @default(cuid())
  merchantId String
  name       String
  key        String    @unique
  keyPrefix  String?
  keyHash    String?
  lastUsed   DateTime?
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now())
  merchant   Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId])
  @@index([keyPrefix])
  @@index([active])
}

model Webhook {
  id              String    @id @default(cuid())
  merchantId      String
  url             String
  events          String[]
  active          Boolean   @default(true)
  secret          String
  description     String?
  lastTriggeredAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  merchant        Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId])
  @@index([active])
  @@index([createdAt])
}

model Invite {
  id        String    @id @default(cuid())
  email     String    @unique
  token     String    @unique @default(cuid())
  used      Boolean   @default(false)
  usedAt    DateTime?
  expiresAt DateTime
  createdAt DateTime  @default(now())
  sentBy    String
}

model PasswordReset {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique @default(cuid())
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model PayrocToken {
  id        String   @id @default(cuid())
  token     String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Affiliate {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  referralCode   String   @unique
  commissionRate Float    @default(10)
  status         String   @default("active")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  referredCount  Int      @default(0)
}

model RefundOperation {
  id                  String   @id @default(cuid())
  operation           String
  payrocPaymentId     String
  payrocRefundId      String?
  idempotencyKey      String   @unique
  amountCents         Int
  description         String?
  operatorUserId      String
  operatorEmail       String
  merchantId          String?
  status              String
  payrocRequestBody   Json?
  payrocResponseBody  Json?
  payrocStatusCode    Int?
  errorMessage        String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([payrocPaymentId])
  @@index([merchantId])
  @@index([operatorUserId])
  @@index([createdAt])
}

model SavedPaymentMethod {
  id                  String    @id @default(cuid())
  merchantId          String
  customerEmail       String
  customerId          String?
  payrocSecureTokenId String    @unique
  payrocToken         String?
  cardScheme          String?
  last4               String?
  expiryMonth         String?
  expiryYear          String?
  cardholderName      String?
  label               String?
  status              String    @default("active")
  mitAgreement        String    @default("unscheduled")
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  lastUsedAt          DateTime?

  merchant            Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  customer            Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([merchantId, customerEmail])
  @@index([payrocSecureTokenId])
  @@index([status])
  @@index([createdAt])
  @@index([customerId])
}

model Device {
  id            String    @id @default(cuid())
  merchantId    String
  serialNumber  String    @unique
  model         String?
  label         String?
  status        String    @default("active")
  pairedAt      DateTime  @default(now())
  lastSeenAt    DateTime?
  lastChargeAt  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  merchant      Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId])
  @@index([status])
  @@index([createdAt])
}

model PayrocPaymentRecord {
  id              String   @id @default(cuid())
  payrocPaymentId String   @unique
  merchantId      String
  amountCents     Int
  currency        String   @default("USD")
  status          String
  source          String
  recordedAt      DateTime @default(now())
  createdAt       DateTime @default(now())

  @@index([merchantId])
  @@index([payrocPaymentId])
  @@index([recordedAt])
}

model WebhookEvent {
  id           String    @id @default(cuid())
  source       String
  eventId      String    @unique
  eventType    String
  payload      Json
  status       String    @default("received")
  processedAt  DateTime?
  errorMessage String?
  ipAddress    String?
  receivedAt   DateTime  @default(now())

  @@index([source])
  @@index([eventType])
  @@index([status])
  @@index([receivedAt])
}

model MerchantApplication {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  legalBusinessName String
  dba               String?
  businessType      String
  ein               String
  businessPhone     String
  website           String?

  addressStreet     String
  addressCity       String
  addressState      String
  addressZip        String
  addressCountry    String   @default("US")

  ownerFullName     String
  ownerEmail        String
  ownerPhone        String
  ownerTitle        String   @default("Owner")

  bankName          String
  accountHolderName String
  routingNumber     String
  accountNumber     String
  accountType       String

  monthlyVolume     String
  averageTicket     String
  mccCode           String
  agreementAccepted          Boolean  @default(false)
  signedAgreementContractId  String?

  // Master review fields
  internalNotes              String?
  approvedAt                 DateTime?
  approvedById               String?
  approvedByEmail            String?
  rejectedAt                 DateTime?
  rejectedById               String?
  rejectedByEmail            String?
  rejectionReason            String?

  status            String   @default("submitted")
  submittedAt       DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorId     String
  actorEmail  String
  actorRole   String
  action      String
  targetType  String
  targetId    String
  merchantId  String?
  metadata    Json?
  createdAt   DateTime @default(now())
  notifications Notification[]

  @@index([actorId])
  @@index([merchantId])
  @@index([targetType, targetId])
  @@index([action])
  @@index([createdAt])
}

model Batch {
  id                  String    @id @default(cuid())
  payrocBatchId       String    @unique
  merchantId          String
  totalAmount         Float
  totalFeesCustomer   Float     @default(0)
  transactionCount    Int       @default(0)
  status              String
  openedAt            DateTime
  closedAt            DateTime?
  settledAt           DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  merchant            Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  payouts             Payout[]

  @@index([merchantId])
  @@index([status])
  @@index([closedAt])
  @@index([payrocBatchId])
}

model Notification {
  id          String    @id @default(cuid())
  userId      String
  merchantId  String?
  category    String
  severity    String
  title       String
  message     String
  link        String?
  metadata    Json?
  auditLogId  String?
  read        Boolean   @default(false)
  readAt      DateTime?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  auditLog    AuditLog? @relation(fields: [auditLogId], references: [id], onDelete: SetNull)

  @@index([userId, read])
  @@index([userId, createdAt])
  @@index([merchantId])
  @@index([category])
  @@index([auditLogId])
}

model MerchantInvite {
  id             String    @id @default(cuid())
  token          String    @unique @default(cuid())
  email          String
  businessName   String
  note           String?
  invitedById    String
  invitedByEmail String
  status         String    @default("pending")
  acceptedById   String?
  acceptedAt     DateTime?
  applicationId  String?
  expiresAt      DateTime
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([token])
  @@index([status])
  @@index([invitedById])
  @@index([email])
  @@index([expiresAt])
}

model Contract {
  id              String   @id @default(cuid())
  merchantId      String
  fileName        String
  mimeType        String
  sizeBytes       Int
  storagePath     String   @unique
  docType         String
  uploadedById    String
  uploadedByEmail String
  uploadedByRole  String
  notes           String?
  createdAt       DateTime @default(now())

  merchant        Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId])
  @@index([docType])
  @@index([uploadedById])
  @@index([createdAt])
}

model Customer {
  id                  String    @id @default(cuid())
  merchantId          String
  email               String
  name                String?
  phone               String?
  firstSeenAt         DateTime  @default(now())
  lastSeenAt          DateTime  @default(now())
  totalTransactions   Int       @default(0)
  totalSpentCents     Int       @default(0)

  merchant            Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  transactions        Transaction[]
  savedPaymentMethods SavedPaymentMethod[]

  @@unique([merchantId, email])
  @@index([merchantId])
  @@index([email])
  @@index([lastSeenAt])
}
