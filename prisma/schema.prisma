generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                     String    @id @default(cuid())
  name                   String?
  email                  String    @unique
  emailVerified          DateTime?
  emailVerificationToken String?   @unique
  image                  String?
  password               String?
  role                   String    @default("merchant")
  approvalStatus               String    @default("pending")
  notificationDigestFrequency  String    @default("off")
  notificationLastDigestSentAt DateTime?
  createdAt                    DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  accounts               Account[]
  sessions               Session[]
  merchant               Merchant?
  merchantApplication    MerchantApplication?
  notifications          Notification[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model Merchant {
  id                    String        @id @default(cuid())
  userId                String        @unique
  businessName          String
  businessType          String?
  email                 String
  phone                 String?
  address               String?
  city                  String?
  state                 String?
  zip                   String?
  stripeAccountId       String?       @unique
  stripeAccountStatus   String        @default("pending")
  stripeOnboardingUrl   String?
  payoutsEnabled        Boolean       @default(false)
  chargesEnabled        Boolean       @default(false)
  monthlyVolume         Float         @default(0)
  totalVolume           Float         @default(0)
  totalTransactions     Int           @default(0)
  plan                  String        @default("starter")
  status                String        @default("active")
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  ein                   String?
  dbaName               String?
  ownerFirstName        String?
  ownerLastName         String?
  ownerDob              String?
  ownerSsnLast4         String?
  ownerTitle            String?
  ownershipPercentage   Int?
  ownerAddress          String?
  bankAccountHolder     String?
  bankRoutingNumber     String?
  bankAccountNumber     String?
  bankAccountType       String?
  fundingSpeed          String?
  avgTransaction        String?
  paymentMethods        String[]
  applicationSubmittedAt DateTime?
  user                  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions          Transaction[]
  payouts               Payout[]
  apiKeys               ApiKey[]
  webhooks              Webhook[]
  savedPaymentMethods   SavedPaymentMethod[]
  devices               Device[]
  batches               Batch[]
  contracts             Contract[]
  customers             Customer[]
  stylists              Stylist[]
  bookings              Booking[]
  cardEntryTokens       CardEntryToken[]
  velocityAlerts        VelocityAlert[]
  chargebackAlerts      ChargebackAlert[]
  locations             Location[]
}

model Transaction {
  id               String    @id @default(cuid())
  merchantId       String
  stripePaymentId  String?   @unique
  amount           Float
  currency         String    @default("usd")
  status           String
  description      String?
  customerEmail    String?
  customerName     String?
  customerId       String?
  stylistId        String?
  bookingId        String?
  tipAmount        Float     @default(0)
  items            Json?
  fee              Float     @default(0)
  net              Float     @default(0)
  refunded         Boolean   @default(false)
  refundAmount     Float     @default(0)
  metadata         Json?
  riskScore        Int       @default(0)
  riskFactors      Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  merchant         Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  customer         Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  stylist          Stylist?  @relation(fields: [stylistId], references: [id], onDelete: SetNull)
  booking          Booking?  @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([stylistId])
  @@index([bookingId])
}

model Payout {
  id             String    @id @default(cuid())
  merchantId     String
  stripePayoutId String?   @unique
  amount         Float
  currency       String    @default("usd")
  status         String
  arrivalDate    DateTime?
  description    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  batchId        String?
  batch          Batch?    @relation(fields: [batchId], references: [id])
  merchant       Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([batchId])
}

model ApiKey {
  id              String           @id @default(cuid())
  merchantId      String
  name            String
  key             String           @unique
  keyPrefix       String?
  keyHash         String?
  lastUsed        DateTime?
  active          Boolean          @default(true)
  createdAt       DateTime         @default(now())
  merchant        Merchant         @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  idempotencyKeys IdempotencyKey[]

  @@index([merchantId])
  @@index([keyPrefix])
  @@index([active])
}

model IdempotencyKey {
  id              String   @id @default(cuid())
  apiKeyId        String
  key             String
  requestHash     String
  responseStatus  Int
  responseBody    Json
  createdAt       DateTime @default(now())
  expiresAt       DateTime

  apiKey          ApiKey   @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  @@unique([apiKeyId, key])
  @@index([expiresAt])
  @@index([apiKeyId, key])
}

model Webhook {
  id              String    @id @default(cuid())
  merchantId      String
  url             String
  events          String[]
  active          Boolean   @default(true)
  secret          String
  description     String?
  lastTriggeredAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  merchant        Merchant           @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  deliveries      WebhookDelivery[]

  @@index([merchantId])
  @@index([active])
  @@index([createdAt])
}

model WebhookDelivery {
  id              String   @id @default(cuid())
  webhookId       String
  merchantId      String
  eventType       String
  eventId         String
  payload         Json
  signature       String

  status          String   @default("pending")
  responseStatus  Int?
  responseBody    String?
  errorMessage    String?
  attemptCount    Int      @default(0)
  lastAttemptAt   DateTime?
  nextRetryAt     DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  webhook         Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@index([merchantId])
  @@index([eventType])
  @@index([status])
  @@index([createdAt])
  @@index([status, nextRetryAt])
}

model Invite {
  id        String    @id @default(cuid())
  email     String    @unique
  token     String    @unique @default(cuid())
  used      Boolean   @default(false)
  usedAt    DateTime?
  expiresAt DateTime
  createdAt DateTime  @default(now())
  sentBy    String
}

model PasswordReset {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique @default(cuid())
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model PayrocToken {
  id        String   @id @default(cuid())
  token     String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Affiliate {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  referralCode   String   @unique
  commissionRate Float    @default(10)
  status         String   @default("active")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  referredCount  Int      @default(0)
}

model RefundOperation {
  id                  String   @id @default(cuid())
  operation           String
  payrocPaymentId     String
  payrocRefundId      String?
  idempotencyKey      String   @unique
  amountCents         Int
  description         String?
  operatorUserId      String
  operatorEmail       String
  merchantId          String?
  status              String
  payrocRequestBody   Json?
  payrocResponseBody  Json?
  payrocStatusCode    Int?
  errorMessage        String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([payrocPaymentId])
  @@index([merchantId])
  @@index([operatorUserId])
  @@index([createdAt])
}

model SavedPaymentMethod {
  id                  String    @id @default(cuid())
  merchantId          String
  customerEmail       String
  customerId          String?
  payrocSecureTokenId String    @unique
  payrocToken         String?
  cardScheme          String?
  last4               String?
  expiryMonth         String?
  expiryYear          String?
  cardholderName      String?
  label               String?
  status              String    @default("active")
  mitAgreement        String    @default("unscheduled")
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  lastUsedAt          DateTime?

  merchant            Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  customer            Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  bookings            Booking[]

  @@index([merchantId, customerEmail])
  @@index([payrocSecureTokenId])
  @@index([status])
  @@index([createdAt])
  @@index([customerId])
}

model Device {
  id            String    @id @default(cuid())
  merchantId    String
  serialNumber  String    @unique
  model         String?
  label         String?
  status        String    @default("active")
  pairedAt      DateTime  @default(now())
  lastSeenAt    DateTime?
  lastChargeAt  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  merchant      Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId])
  @@index([status])
  @@index([createdAt])
}

model PayrocPaymentRecord {
  id              String   @id @default(cuid())
  payrocPaymentId String   @unique
  merchantId      String
  amountCents     Int
  currency        String   @default("USD")
  status          String
  source          String
  recordedAt      DateTime @default(now())
  createdAt       DateTime @default(now())

  @@index([merchantId])
  @@index([payrocPaymentId])
  @@index([recordedAt])
}

model WebhookEvent {
  id           String    @id @default(cuid())
  source       String
  eventId      String    @unique
  eventType    String
  payload      Json
  status       String    @default("received")
  processedAt  DateTime?
  errorMessage String?
  ipAddress    String?
  receivedAt   DateTime  @default(now())

  @@index([source])
  @@index([eventType])
  @@index([status])
  @@index([receivedAt])
}

model MerchantApplication {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  legalBusinessName String
  dba               String?
  businessType      String
  ein               String
  businessPhone     String
  website           String?

  addressStreet     String
  addressCity       String
  addressState      String
  addressZip        String
  addressCountry    String   @default("US")

  ownerFullName     String
  ownerEmail        String
  ownerPhone        String
  ownerTitle        String   @default("Owner")

  bankName          String
  accountHolderName String
  routingNumber     String
  accountNumber     String
  accountType       String

  monthlyVolume     String
  averageTicket     String
  mccCode           String
  agreementAccepted          Boolean  @default(false)
  signedAgreementContractId  String?

  // Master review fields
  internalNotes              String?
  approvedAt                 DateTime?
  approvedById               String?
  approvedByEmail            String?
  rejectedAt                 DateTime?
  rejectedById               String?
  rejectedByEmail            String?
  rejectionReason            String?

  // Payroc boarding fields
  payrocSubmittedAt          DateTime?
  payrocSubmittedById        String?
  payrocSubmittedByEmail     String?
  payrocActivatedAt          DateTime?
  payrocActivatedById        String?
  payrocActivatedByEmail     String?
  payrocMid                  String?

  status            String   @default("submitted")
  submittedAt       DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorId     String
  actorEmail  String
  actorRole   String
  action      String
  targetType  String
  targetId    String
  merchantId  String?
  metadata    Json?
  createdAt   DateTime @default(now())
  notifications Notification[]

  @@index([actorId])
  @@index([merchantId])
  @@index([targetType, targetId])
  @@index([action])
  @@index([createdAt])
}

model Batch {
  id                  String    @id @default(cuid())
  payrocBatchId       String    @unique
  merchantId          String
  totalAmount         Float
  totalFeesCustomer   Float     @default(0)
  transactionCount    Int       @default(0)
  status              String
  openedAt            DateTime
  closedAt            DateTime?
  settledAt           DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  merchant            Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  payouts             Payout[]

  @@index([merchantId])
  @@index([status])
  @@index([closedAt])
  @@index([payrocBatchId])
}

model Notification {
  id          String    @id @default(cuid())
  userId      String
  merchantId  String?
  category    String
  severity    String
  title       String
  message     String
  link        String?
  metadata    Json?
  auditLogId  String?
  read        Boolean   @default(false)
  readAt      DateTime?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  auditLog    AuditLog? @relation(fields: [auditLogId], references: [id], onDelete: SetNull)

  @@index([userId, read])
  @@index([userId, createdAt])
  @@index([merchantId])
  @@index([category])
  @@index([auditLogId])
}

model MerchantInvite {
  id             String    @id @default(cuid())
  token          String    @unique @default(cuid())
  email          String
  businessName   String
  note           String?
  invitedById    String
  invitedByEmail String
  status         String    @default("pending")
  acceptedById   String?
  acceptedAt     DateTime?
  applicationId  String?
  expiresAt      DateTime
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([token])
  @@index([status])
  @@index([invitedById])
  @@index([email])
  @@index([expiresAt])
}

model Contract {
  id              String   @id @default(cuid())
  merchantId      String
  fileName        String
  mimeType        String
  sizeBytes       Int
  storagePath     String   @unique
  docType         String
  uploadedById    String
  uploadedByEmail String
  uploadedByRole  String
  notes           String?
  createdAt       DateTime @default(now())

  merchant        Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId])
  @@index([docType])
  @@index([uploadedById])
  @@index([createdAt])
}

model Customer {
  id                  String    @id @default(cuid())
  merchantId          String
  email               String
  name                String?
  phone               String?
  firstSeenAt         DateTime  @default(now())
  lastSeenAt          DateTime  @default(now())
  totalTransactions   Int       @default(0)
  totalSpentCents     Int       @default(0)

  merchant            Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  transactions        Transaction[]
  savedPaymentMethods SavedPaymentMethod[]
  bookings            Booking[]

  @@unique([merchantId, email])
  @@index([merchantId])
  @@index([email])
  @@index([lastSeenAt])
}

model Stylist {
  id              String    @id @default(cuid())
  merchantId      String
  name            String
  email           String?
  phone           String?
  role            String    @default("stylist")
  commissionRate  Float?
  hourlyRate      Float?
  payoutMethod    String?
  status          String    @default("active")
  externalRef     String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  merchant        Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  transactions    Transaction[]
  bookings        Booking[]

  @@unique([merchantId, externalRef])
  @@index([merchantId])
  @@index([status])
  @@index([email])
}

model Booking {
  id                    String    @id @default(cuid())
  merchantId            String
  stylistId             String?
  customerId            String?
  savedPaymentMethodId  String?

  scheduledFor          DateTime
  durationMinutes       Int       @default(60)
  serviceCode           String?
  serviceName           String?
  expectedAmountCents   Int       @default(0)

  status                String    @default("booked")
  authHoldId            String?
  authHoldAmountCents   Int?
  authHoldExpiresAt     DateTime?

  externalBookingId     String?
  externalSource        String?

  notes                 String?

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  merchant              Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  stylist               Stylist?  @relation(fields: [stylistId], references: [id], onDelete: SetNull)
  customer              Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  savedPaymentMethod    SavedPaymentMethod? @relation(fields: [savedPaymentMethodId], references: [id], onDelete: SetNull)
  transactions          Transaction[]
  cardEntryTokens       CardEntryToken[]

  @@unique([merchantId, externalSource, externalBookingId])
  @@index([merchantId])
  @@index([stylistId])
  @@index([customerId])
  @@index([scheduledFor])
  @@index([status])
}

model CardEntryToken {
  id                    String    @id @default(cuid())
  merchantId            String
  bookingId             String?
  customerPhone         String
  customerName          String?
  customerEmail         String?

  signedToken           String    @unique
  expiresAt             DateTime
  usedAt                DateTime?
  status                String    @default("active")
  resultingSavedPaymentMethodId String?

  smsSentAt             DateTime?
  smsSid                String?

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  merchant              Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  booking               Booking?  @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@index([merchantId])
  @@index([bookingId])
  @@index([status])
  @@index([expiresAt])
}

model VelocityAlert {
  id              String   @id @default(cuid())
  merchantId      String
  ruleCode        String
  ruleDescription String
  severity        String   @default("warn")
  status          String   @default("detected")
  customerId      String?
  customerEmail   String?
  cardLast4       String?
  triggerData     Json?
  amountCents     Int?
  detectedAt      DateTime @default(now())
  reviewedAt      DateTime?
  reviewedBy      String?

  merchant        Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId])
  @@index([ruleCode])
  @@index([status])
  @@index([detectedAt])
  @@index([customerId])
}

model ChargebackAlert {
  id               String   @id @default(cuid())
  merchantId       String
  threshold        String
  ratioPercent     Float
  chargebackCount  Int
  totalCharges     Int
  windowDays       Int      @default(90)
  emailSentTo      String?
  smsSentTo        String?
  emailSentAt      DateTime?
  smsSentAt        DateTime?
  createdAt        DateTime @default(now())

  merchant         Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId])
  @@index([threshold])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────
// Location — Phase 10.8 multi-location support
//
// A salon owner with multiple physical locations gets one Merchant row
// and N Location rows. Charges, customers, stylists, bookings, and
// reports can be scoped per-location.
//
// payrocTerminalId is reserved for Phase 9.4 cutover when each location
// gets its own Payroc MID. For now (UAT, single House Account), this
// stays nullable.
// ─────────────────────────────────────────────────────────────────────
model Location {
  id                  String    @id @default(cuid())
  merchantId          String
  name                String
  addressLine1        String?
  addressLine2        String?
  city                String?
  state               String?
  zip                 String?
  phone               String?
  timezone            String    @default("America/Chicago")
  payrocTerminalId    String?
  status              String    @default("active")
  isPrimary           Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  merchant            Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId])
  @@index([merchantId, status])
  @@index([payrocTerminalId])
}

// ─────────────────────────────────────────────────────────────────
// CertTestSession + CertTestRun — Payroc cert test plan execution
//
// One CertTestSession represents a batch like "Reyna Pay Production
// Cert #1 — 2026-04-30". Each session is seeded with all 98 test
// cases as CertTestRun rows in pending status when created. Tests
// transition pending → running → passed/failed/skipped as they execute.
//
// This is internal master-portal tooling. Used to track progress
// against Matt's structured cert plan and to export filled-in
// spreadsheet results back to Payroc. Reusable for future cert runs
// (resellers, additional verticals).
// ─────────────────────────────────────────────────────────────────

model CertTestSession {
  id              String          @id @default(cuid())
  name            String
  description     String?
  status          String          @default("in_progress")  // in_progress | complete | abandoned
  merchantId      String?
  apiKeyId        String?
  terminalSerial  String?
  createdByUserId String

  totalTests      Int             @default(0)
  passedTests     Int             @default(0)
  failedTests     Int             @default(0)
  skippedTests    Int             @default(0)

  startedAt       DateTime        @default(now())
  completedAt     DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  runs            CertTestRun[]

  @@index([status])
  @@index([createdByUserId])
  @@index([createdAt])
}

model CertTestRun {
  id            String           @id @default(cuid())
  sessionId     String

  testCaseId    String           // matches the id in lib/cert/test-cases.ts
  sheetName     String           // "CNP" or "CP"
  sectionName   String           // e.g. "Credit Card Sale NO Secure Token"
  transactionType String          // e.g. "Sale", "Pre-Authorization", "Capture", "Void/Reversal"
  scenario      String           // full scenario directions from spreadsheet
  expectedResult String          // e.g. "Approved", "Decline", "Approve/Decline"
  required      Boolean          @default(false)

  status        String           @default("pending")  // pending | running | passed | failed | skipped
  paymentId     String?          // Payroc paymentId / uniqueRef when test runs
  sessionToken  String?          // For Hosted Fields tests
  notes         String?
  errorMessage  String?
  testAmountCents Int?           // Amount used (controls Payroc test response)
  testCardLast4 String?

  ranAt         DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  session       CertTestSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([sessionId, sheetName])
  @@index([sessionId, status])
  @@index([testCaseId])
}
